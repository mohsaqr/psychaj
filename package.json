{
  "name": "psychaj",
  "version": "0.1.0",
  "description": "Psychometric network analysis in JavaScript — Pearson, partial correlation, GLASSO, mlVAR, graphicalVAR, NCT, bootstrap, community detection, PageRank",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "require": {
        "types": "./dist/core/index.d.cts",
        "default": "./dist/core/index.cjs"
      }
    },
    "./estimation": {
      "import": {
        "types": "./dist/estimation/index.d.ts",
        "default": "./dist/estimation/index.js"
      },
      "require": {
        "types": "./dist/estimation/index.d.cts",
        "default": "./dist/estimation/index.cjs"
      }
    },
    "./models": {
      "import": {
        "types": "./dist/models/index.d.ts",
        "default": "./dist/models/index.js"
      },
      "require": {
        "types": "./dist/models/index.d.cts",
        "default": "./dist/models/index.cjs"
      }
    },
    "./validation": {
      "import": {
        "types": "./dist/validation/index.d.ts",
        "default": "./dist/validation/index.js"
      },
      "require": {
        "types": "./dist/validation/index.d.cts",
        "default": "./dist/validation/index.cjs"
      }
    },
    "./graph": {
      "import": {
        "types": "./dist/graph/index.d.ts",
        "default": "./dist/graph/index.js"
      },
      "require": {
        "types": "./dist/graph/index.d.cts",
        "default": "./dist/graph/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepare": "tsup",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "carm": "github:mohsaqr/Carm#main"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
